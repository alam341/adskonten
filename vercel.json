{
  "version": 2,
  "builds": [
    { "src": "api/proxy/index.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "*.css", "use": "@vercel/static" },
    { "src": "*.js", "use": "@vercel/static", "config": { "excludeFiles": "api/**" } }
  ],
  "routes": [
    { "src": "/api/proxy", "dest": "/api/proxy/index.js" },
    { "src": "/style.css", "dest": "/style.css" },
    { "src": "/app.js", "dest": "/app.js" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
